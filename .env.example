# ── Wallet ────────────────────────────────────────────────────
PRIVATE_KEY=your_polygon_wallet_private_key_here

# Polygon RPC — free community nodes (no key required, pick one):
POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
#POLYGON_RPC=https://polygon.llamarpc.com
#POLYGON_RPC=https://polygon.drpc.org
# Authenticated private RPC (higher rate limits):
#POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
#POLYGON_RPC=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
#POLYGON_RPC=https://polygon.quiknode.pro/YOUR_QUICKNODE_KEY

CHAIN_ID=137

# ── Polymarket CLOB API Keys (L2 auth — required for trading) ─
# Auto-generated from your wallet on first boot — leave blank.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ── Trading limits ────────────────────────────────────────────
MAX_POSITION_SIZE=10000
MAX_DAILY_LOSS=5000
MIN_CONFIDENCE=0.6
MAX_SLIPPAGE=0.01
DEFAULT_STRATEGY=adaptive

# ── Notifications ─────────────────────────────────────────────
NOTIFICATION_COOLDOWN=30
SEND_ON_EVERY_TRADE=true
SEND_DAILY_SUMMARY=true
SEND_KEY_REMINDERS=true

# ── Alert channel (optional) ─────────────────────────────────
CONTACT_NAME=
ALERT_EMAIL=
